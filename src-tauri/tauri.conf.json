{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Meyatu Code",
  "version": "0.1.0",
  "identifier": "com.meyatu.code",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Meyatu Code",
        "width": 1400,
        "height": 781,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; connect-src 'self' https://api.meyatu.io https://github.com"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "MEYATU LLC",
    "copyright": "Copyright (c) 2026 MEYATU LLC / 长沙梅亚图智能科技有限公司",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
